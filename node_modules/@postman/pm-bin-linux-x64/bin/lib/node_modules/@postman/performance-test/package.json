{
  "name": "@postman/performance-test",
  "version": "0.0.69",
  "description": "Postman performance testing library",
  "main": "index.js",
  "scripts": {
    "start": "npm run build && node examples/fixed.js",
    "start-peak": "npm run build && node examples/peak.js",
    "start-ramp": "npm run build && node examples/ramp.js",
    "start-spike": "npm run build && node examples/spike.js",
    "start-basic": "npm run build && node examples/basic.js",
    "report": "npm run build && node reports/server.js",
    "build": "rm -rf dist && npx esbuild src/*.js --bundle --minify --platform=node --outdir=dist",
    "api-server": "node reports/api-server.js",
    "test": "npm run test:coverage",
    "test:watch": "mocha 'test/unit/**/*.test.js' --timeout 5000 --watch",
    "test:unit": "mocha 'test/unit/**/*.test.js' --timeout 5000",
    "test:coverage": "nyc npm run test:unit"
  },
  "files": [
    "dist/",
    "index.js",
    "README.md"
  ],
  "author": "Postman Inc.",
  "license": "ISC",
  "dependencies": {
    "postman-collection": "^5.0.2",
    "postman-runtime": "^7.47.0",
    "systeminformation": "^5.23.16",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.6",
    "express": "^5.1.0",
    "mocha": "^11.7.4",
    "nyc": "^17.1.0",
    "terser": "^5.43.1"
  }
}
